  "services": {
    "refresh_data": {
      "name": "Refresh data",
      "description": "Refresh Aptner data immediately.",
      "fields": {
        "entry_id": {
          "name": "Entry ID",
          "description": "Optional config entry ID when multiple Aptner accounts are configured."
        }
      }
    },
    "submit_vote": {
      "name": "Submit vote",
      "description": "Submit a vote selection to Aptner.",
      "fields": {
        "entry_id": {
          "name": "Entry ID",
          "description": "Optional config entry ID when multiple Aptner accounts are configured."
        },
        "vote_id": {
          "name": "Vote ID",
          "description": "The Aptner vote ID."
        },
        "selection_item_id": {
          "name": "Selection item ID",
          "description": "The selected vote item ID."
        },
        "sign_file_url": {
          "name": "Sign file URL",
          "description": "Optional signature file URL for sign-required votes."
        }
      }
    },
    "submit_survey": {
      "name": "Submit survey",
      "description": "Submit answers to an Aptner survey.",
      "fields": {
        "entry_id": {
          "name": "Entry ID",
          "description": "Optional config entry ID when multiple Aptner accounts are configured."
        },
        "survey_id": {
          "name": "Survey ID",
          "description": "The Aptner survey ID."
        },
        "answers": {
          "name": "Answers",
          "description": "A list of answer objects with question_id and answer."
        }
      }
    },
    "register_visit_vehicle": {
      "name": "Register visit vehicle",
      "description": "Register a visitor car using the legacy visit reservation API.",
      "fields": {
        "entry_id": {
          "name": "Entry ID",
          "description": "Optional config entry ID when multiple Aptner accounts are configured."
        },
        "car_no": {
          "name": "Car number",
          "description": "The visitor car plate number."
        },
        "visitor_phone": {
          "name": "Visitor phone",
          "description": "The visitor phone number."
        },
        "visit_date": {
          "name": "Visit date",
          "description": "Visit date in the same format expected by the Aptner API."
        },
        "visit_purpose": {
          "name": "Visit purpose",
          "description": "Purpose text for the visit."
        }
      }
    },
    "cancel_visit_vehicle": {
      "name": "Cancel visit vehicle",
      "description": "Cancel an existing visitor car reservation.",
      "fields": {
        "entry_id": {
          "name": "Entry ID",
          "description": "Optional config entry ID when multiple Aptner accounts are configured."
        },
        "visit_reserve_idx": {
          "name": "Visit reservation ID",
          "description": "The legacy visitor reservation ID to cancel."
        }
      }
    }
